@startuml
skinparam backgroundColor #EEF2F5
skinparam participantBackgroundColor #A9C2C3
skinparam participantBorderColor gray
skinparam sequenceLifeLineBackgroundColor #CC3333
skinparam sequenceArrowColor black
skinparam noteBackgroundColor #FDE284
skinparam noteBorderColor #FDE284

note left of server: logout user: get

participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as router
participant "<<controllers>>\n:auth" as controller

-> server : req.get('/api/v1/auth/logout')
activate server

server -> router : app.use('/api/v1/auth', auth)
activate router

router -> controller : logout
activate controller

controller -> controller : res.cookie('token', 'none')

<-- controller : response
deactivate controller
deactivate router
deactivate server
@enduml