-> server : req.put('/:id/confirm')
activate server

server -> router : app.use('/reservations', reservations)
activate router

router -> auth : protect, authorize('admin')
activate auth
auth --> router : next()
deactivate auth

router -> controller : confirmReservation
activate controller

controller -> model : findById(req.params.id)
activate model
model -> db : find()
activate db
